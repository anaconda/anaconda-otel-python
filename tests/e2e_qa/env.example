# OpenTelemetry Environment Configuration
# Copy this file to .env and configure for your environment

# ============================================================================
# ENVIRONMENT SELECTION
# ============================================================================
# Choose your target environment:
#   - staging-internal: For testing from internal services/GitHub runners (DEFAULT)
#   - staging-public: For testing OAuth authentication (currently behind WARP)
#   - production-external: For real production data with API key authentication
#   - production-internal: For real production data from internal services
#
# ⚠️  WARNING: Only send test data to staging environments!
# ============================================================================
OTEL_ENVIRONMENT=staging-internal

# ============================================================================
# CUSTOM ENDPOINT (Optional)
# ============================================================================
# Override the environment-based endpoint selection with a custom URL
# Leave commented to use the default endpoint for your selected environment
#
# OTEL_ENDPOINT=https://custom-endpoint.example.com/v1/metrics

# ============================================================================
# DEBUGGING
# ============================================================================
# Enable console exporter to see telemetry output in the console
# Useful for debugging and verifying data before sending to remote endpoint
# Values: true, false
OTEL_CONSOLE_EXPORTER=true

# ============================================================================
# AUTHENTICATION (Production External Only)
# ============================================================================
# API key for production-external environment
# Required only when OTEL_ENVIRONMENT=production-external
# Use SendSafely for secure API key transmission
#
# OTEL_API_KEY=your-api-key-here

# ============================================================================
# ENVIRONMENT REFERENCE
# ============================================================================
#
# Staging - Internal (Default for testing):
#   - Behind WARP: https://metrics.stage.anacondaconnect.com/v1/metrics
#   - Internal: https://metrics.stage.internal.anacondaconnect.com/v1/metrics
#   - K8s (dev): http://metrics-collector.opentelemetry.svc.cluster.local
#
# Staging - Public (OAuth testing):
#   - https://metrics.stage-oauth.anacondaconnect.com/v1/metrics
#   - Currently behind WARP for testing phase
#
# Production - External (Requires API key):
#   - Standard: https://metrics.anaconda.com/v1/metrics
#   - Behind WARP: https://metrics.w.anaconda.com/v1/metrics
#
# Production - Internal (No auth required):
#   - Internal: https://metrics.internal.anaconda.com/v1/metrics
#   - K8s (prod): http://metrics-collector.opentelemetry.svc.cluster.local
#
# ============================================================================
