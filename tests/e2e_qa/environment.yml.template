# Conda Environment for E2E QA Hello-World Examples
# 
# This file defines the conda environment for running the anaconda-opentelemetry
# hello-world demonstration examples.
#
# Usage:
#   conda env create -f environment.yml
#   conda activate e2e-qa-examples
#
# To update an existing environment:
#   conda env update -f environment.yml --prune

name: e2e-qa-examples

dependencies:
  # Python version (3.10 recommended, 3.9+ required)
  - python=3.10
  
  # The SDK being demonstrated
  - anaconda-opentelemetry
  
  # Optional development tools (uncomment if needed)
  # - black   # Code formatting
  # - flake8  # Linting

# Notes:
# 1. No channels specified - uses default Anaconda channels
# 2. No additional dependencies needed for hello-world examples
# 3. See _docs/01_requirements.md for Python version details
